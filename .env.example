# Penny Reseller - Environment Variables

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=penny_reseller

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# APIs - Get these from the respective platforms
WALMART_API_KEY=your_walmart_api_key
LOWES_API_KEY=your_lowes_api_key
HOME_DEPOT_API_KEY=your_home_depot_api_key
AMAZON_SP_API_KEY=your_amazon_sp_api_key
EBAY_API_KEY=your_ebay_api_key

# Server
NODE_ENV=development
PORT=5000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
